{
	"name": "@reshaped/root",
	"private": true,
	"description": "Reshaped monorepo root",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/reshaped-ui/reshaped.git"
	},
	"scripts": {
		"dev": "storybook dev -p 3001 --disable-telemetry",
		"clean": "pnpm -r run clean",
		"commit": "git-cz",
		"changeset": "changeset",
		"build": "pnpm -r run build",
		"build:stories": "pnpm --filter reshaped run build:stories",
		"build:themes": "pnpm --filter reshaped run build:themes",
		"build:storybook": "storybook build -o dist/app --disable-telemetry",
		"build:chromatic": "STORYBOOK_ENV=chromatic storybook build",
		"release": "sh ./bin/release.sh",
		"release:canary": "sh ./bin/release-canary.sh",
		"release:local": "pnpm --filter reshaped run release:local",
		"chromatic": "chromatic -b build:chromatic --project-token=$(cat .chromatic) --only-changed --externals '.storybook/public/**'",
		"test:vrt": "pnpm chromatic",
		"test:browser": "pnpm --filter reshaped run test:browser",
		"test:unit": "pnpm --filter reshaped run test:unit",
		"test:size": "size-limit",
		"lint": "pnpm lint:js && pnpm lint:css",
		"lint:js": "eslint './packages/**/*.{ts,tsx}' --fix",
		"lint:css": "stylelint 'packages/**/*.css'"
	},
	"devDependencies": {
		"@changesets/changelog-github": "0.5.1",
		"@changesets/cli": "2.29.7",
		"@commitlint/cli": "20.1.0",
		"@commitlint/config-conventional": "20.0.0",
		"@commitlint/types": "20.0.0",
		"@csstools/postcss-global-data": "3.1.0",
		"@eslint/js": "9.38.0",
		"@size-limit/preset-big-lib": "11.2.0",
		"@storybook/addon-a11y": "10.2.0-alpha.3",
		"@storybook/addon-docs": "10.2.0-alpha.3",
		"@storybook/addon-mcp": "0.1.4-next.2",
		"@storybook/addon-vitest": "10.2.0-alpha.3",
		"@storybook/react-vite": "10.2.0-alpha.3",
		"@testing-library/user-event": "14.6.1",
		"@types/culori": "4.0.1",
		"@types/events": "3.0.3",
		"@types/node": "24.9.2",
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"@vitejs/plugin-react": "5.1.0",
		"@vitest/browser": "4.0.4",
		"@vitest/browser-playwright": "4.0.4",
		"@vitest/coverage-istanbul": "4.0.4",
		"@vitest/coverage-v8": "4.0.4",
		"chromatic": "13.3.2",
		"cssnano": "7.1.2",
		"eslint": "9.38.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-prettier": "5.5.4",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"lefthook": "2.0.1",
		"playwright": "1.56.1",
		"postcss": "8.5.6",
		"postcss-cli": "11.0.1",
		"postcss-custom-media": "11.0.6",
		"postcss-each": "1.1.0",
		"postcss-nested": "7.0.2",
		"prettier": "3.6.2",
		"react": "18",
		"react-dom": "18",
		"react-shadow": "20.6.0",
		"resolve-tspaths": "0.8.23",
		"size-limit": "11.2.0",
		"storybook": "10.2.0-alpha.3",
		"stylelint": "16.25.0",
		"stylelint-config-prettier": "9.0.5",
		"stylelint-config-standard": "39.0.1",
		"ts-node": "10.9.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.46.2",
		"vite": "7.1.12",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "4.0.4",
		"vitest-browser-react": "2.0.2"
	},
	"engines": {
		"node": ">=22"
	},
	"size-limit": [
		{
			"name": "Library / JS",
			"path": "packages/reshaped/dist/bundle.js",
			"webpack": false
		},
		{
			"name": "Library / CSS",
			"path": "packages/reshaped/dist/bundle.css",
			"webpack": false
		},
		{
			"name": "Theming / JS",
			"path": "packages/reshaped/dist/tests/themingWithoutDefinition.js",
			"webpack": true
		},
		{
			"name": "Theming with a default theme definition / JS",
			"path": "packages/reshaped/dist/tests/themingWithDefinition.js",
			"webpack": true
		}
	]
}
