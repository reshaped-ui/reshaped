{
	"name": "@reshaped/root",
	"private": true,
	"description": "Reshaped monorepo root",
	"license": "MIT",
	"packageManager": "pnpm@11.5.2",
	"repository": {
		"type": "git",
		"url": "https://github.com/reshaped-ui/reshaped.git"
	},
	"scripts": {
		"dev": "pnpm -r --parallel run dev",
		"clean": "pnpm -r run clean",
		"changeset": "changeset",
		"build": "pnpm -r run build",
		"build:stories": "pnpm --filter reshaped run build:stories",
		"build:themes": "pnpm --filter @reshaped/theming run build && pnpm --filter reshaped run build:themes",
		"build:storybook": "storybook build -o dist/app --disable-telemetry",
		"build:chromatic": "STORYBOOK_ENV=chromatic storybook build",
		"release": "bash ./bin/release.sh",
		"release:canary": "bash ./bin/release-canary.sh",
		"release:local": "bash ./bin/release-local.sh",
		"chromatic": "chromatic -b build:chromatic --project-token=$(cat .chromatic) --only-changed --externals '.storybook/public/**'",
		"test:vrt": "pnpm chromatic",
		"test:browser": "pnpm -r run test:browser",
		"test:unit": "pnpm -r run test:unit",
		"test:size": "pnpm --filter @reshaped/theming run build && pnpm --filter reshaped run build:size && size-limit",
		"lint": "pnpm lint:format && pnpm lint:js && pnpm lint:css",
		"lint:js": "oxlint --deny-warnings",
		"lint:css": "stylelint --max-warnings 0 --allow-empty-input 'packages/**/*.css'",
		"lint:format": "oxfmt"
	},
	"devDependencies": {
		"@changesets/changelog-github": "0.7.0",
		"@changesets/cli": "2.31.0",
		"@csstools/postcss-global-data": "4.0.0",
		"@size-limit/preset-big-lib": "12.1.0",
		"@storybook/addon-a11y": "10.5.0",
		"@storybook/addon-docs": "10.5.0",
		"@storybook/addon-mcp": "0.7.0",
		"@storybook/addon-vitest": "10.5.0",
		"@storybook/react-vite": "10.5.0",
		"@types/culori": "4.0.1",
		"@types/events": "3.0.3",
		"@types/node": "26.1.1",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"@vitest/browser": "4.1.10",
		"@vitest/browser-playwright": "4.1.10",
		"@vitest/coverage-istanbul": "4.1.10",
		"@vitest/coverage-v8": "4.1.10",
		"chromatic": "18.0.1",
		"cssnano": "8.0.2",
		"lefthook": "2.1.10",
		"oxfmt": "0.53.0",
		"oxlint": "1.73.0",
		"playwright": "1.61.1",
		"postcss": "8.5.16",
		"postcss-cli": "11.0.1",
		"postcss-custom-media": "12.0.1",
		"postcss-each": "1.1.0",
		"postcss-nested": "7.0.2",
		"react": "18",
		"react-dom": "18",
		"react-shadow": "20.6.0",
		"rimraf": "6.1.3",
		"shx": "0.4.0",
		"size-limit": "12.1.0",
		"storybook": "10.5.0",
		"stylelint": "17.14.0",
		"stylelint-browser-compat": "1.0.0-beta.180",
		"stylelint-config-prettier": "9.0.5",
		"stylelint-config-standard": "40.0.0",
		"tsc-alias": "1.9.0",
		"tsc-watch": "7.2.1",
		"typescript": "7.0.2",
		"vite": "8.1.4",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.1.10",
		"vitest-browser-react": "2.2.0"
	},
	"size-limit": [
		{
			"name": "Library / JS",
			"path": "packages/reshaped/dist/bundle.js",
			"webpack": false
		},
		{
			"name": "Library / CSS",
			"path": "packages/reshaped/dist/bundle.css",
			"webpack": false
		},
		{
			"name": "Theming / JS",
			"path": "packages/theming/dist/tests/themingWithoutDefinition.js",
			"webpack": true
		},
		{
			"name": "Theming with a default theme definition / JS",
			"path": "packages/theming/dist/tests/themingWithDefinition.js",
			"webpack": true
		}
	],
	"engines": {
		"node": ">=22"
	}
}
